# Arso .gitattributes

# Normalize text files
* text=auto eol=lf

# Markdown
*.md text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf
*.zsh text eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Source files
*.go text eol=lf
*.py text eol=lf
*.ts text eol=lf
*.js text eol=lf
*.java text eol=lf
*.kt text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.toml text eol=lf

# Binary/data files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.fits binary
*.fit binary
*.ser binary
*.iq binary
*.bin binary
*.db binary
*.sqlite binary
*.sqlite3 binary
